# ─── Server Environment Variables ──────────────────────────────────────────
# Copy this file to .env for local development.
# On Vercel, set these in Project Settings → Environment Variables.

# Runtime
NODE_ENV=development
# PORT is managed by Vercel automatically — do not set it in the Vercel dashboard.

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local:
MONGO_URI=mongodb://localhost:27017/corizolinks
# Atlas (use this in production / Vercel):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corizolinks?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# ─── CORS ────────────────────────────────────────────────────────────────────
# Must match your deployed frontend URL exactly (no trailing slash).
CLIENT_URL=http://localhost:5173
# Production example: CLIENT_URL=https://corizo-links-frontend.vercel.app

# ─── Seed script defaults ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@corizo.in
ADMIN_PASSWORD=Admin@123456
