# Server Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/corizolinks
# For Atlas: MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/corizolinks

# JWT — use a long random secret in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7

# CORS — your frontend URL
CLIENT_URL=http://localhost:5173

# Seed defaults (used by npm run seed)
ADMIN_EMAIL=admin@corizo.in
ADMIN_PASSWORD=Admin@123456
